page {
  --ink: #1a2332;
  --ink-soft: #3b4656;
  --muted: #586374;
  --accent: #3b6fd4;
  --accent-deep: #2f5cb8;
  --accent-soft: #e8eef9;
  --price: #b42318;
  --page-bg: #e4e8ec;
  --surface: #eef1f4;
  --surface-raised: #f4f6f8;
  --border: #cfd5dd;

  background: var(--page-bg);
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.container {
  padding: 24rpx 28rpx 40rpx;
}

.card {
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 8rpx;
}

.page-desc {
  font-size: 26rpx;
  color: var(--muted);
  margin-bottom: 24rpx;
}

.price {
  color: var(--price);
  font-weight: 700;
}

.muted {
  color: var(--muted);
}

.btn-primary {
  background: var(--accent);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.btn-primary::after {
  border: none;
}

.btn-ghost {
  background: var(--surface-raised);
  color: var(--ink-soft);
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 28rpx;
}

.btn-ghost::after {
  border: none;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
  color: var(--muted);
}
