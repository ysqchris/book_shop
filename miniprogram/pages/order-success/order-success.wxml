<view class="container" wx:if="{{order}}">
  <view class="card head">
    <view class="ok">下单成功</view>
    <view class="muted">请尽快联系店家，确认品相后完成线下付款</view>
  </view>

  <view class="card">
    <view class="line">订单号：{{order.orderNo}}</view>
    <view class="line">应付金额：<text class="price">¥{{payAmount}}</text></view>
    <view class="line">状态：待线下确认付款</view>
  </view>

  <view class="card" wx:if="{{shopContact}}">
    <view class="section-title">店家联系方式</view>
    <view class="line" wx:if="{{shopContact.name}}">店家 {{shopContact.name}}</view>
    <view class="line" wx:if="{{shopContact.phone}}">
      电话
      <text class="link" data-phone="{{shopContact.phone}}" bindtap="callPhone"> {{shopContact.phone}}</text>
    </view>
    <view class="line" wx:if="{{shopContact.address}}">地址 {{shopContact.address}}</view>
    <view class="line" wx:if="{{shopContact.wechat}}">微信 {{shopContact.wechat}}</view>
    <image
      wx:if="{{shopContact.wechatQrcodeUrl}}"
      class="qrcode"
      src="{{shopContact.wechatQrcodeUrl}}"
      mode="aspectFit"
      show-menu-by-longpress
      data-url="{{shopContact.wechatQrcodeUrl}}"
      bindtap="previewQrcode"
    />
    <view class="muted tip" wx:if="{{shopContact.tip}}">{{shopContact.tip}}</view>
  </view>

  <view class="actions">
    <button class="btn-primary action" bindtap="goOrders">查看我的订单</button>
    <button class="btn-ghost action" bindtap="goBooks">继续逛逛</button>
  </view>
</view>

<view class="empty" wx:elif="{{!loading}}">订单不存在</view>
