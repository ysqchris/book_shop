.tip {
  color: var(--accent-deep);
  background: var(--accent-soft);
  border-color: #c5d4ef;
  font-size: 26rpx;
  line-height: 1.6;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.line {
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.qrcode {
  width: 260rpx;
  height: 260rpx;
  margin-top: 16rpx;
  background: var(--surface-raised);
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
}

.tip-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.goods {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.goods:last-of-type {
  border-bottom: none;
}

.cover {
  width: 110rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background: #e2e6eb;
}

.body {
  flex: 1;
  min-width: 0;
}

.title {
  font-weight: 600;
}

.row {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
}

.total {
  margin-top: 16rpx;
  text-align: right;
  font-size: 34rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  margin-bottom: 8rpx;
  color: var(--ink-soft);
  font-size: 24rpx;
}

.input,
.textarea {
  width: 100%;
  padding: 16rpx 20rpx;
  background: var(--surface-raised);
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  box-sizing: border-box;
  font-size: 26rpx;
}

.textarea {
  min-height: 120rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.action {
  flex: 1;
  margin: 0;
}

.go {
  margin-top: 24rpx;
  width: 240rpx;
}
