.hero {
  display: flex;
  gap: 20rpx;
  align-items: center;
  margin-bottom: 24rpx;
}

.logo {
  width: 108rpx;
  height: 96rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: #f5d84a;
  flex-shrink: 0;
}

.hero-text .page-title {
  margin-bottom: 4rpx;
}

.hero-text .page-desc {
  margin-bottom: 0;
}

.toolbar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: var(--surface-raised);
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 26rpx;
}

.sort {
  min-width: 160rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 20rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--ink-soft);
  text-align: center;
}

.category-bar {
  white-space: nowrap;
  margin-bottom: 24rpx;
  padding-bottom: 8rpx;
}

.chip {
  display: inline-block;
  padding: 10rpx 22rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: var(--surface);
  color: var(--ink-soft);
  font-size: 24rpx;
}

.chip.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
  font-weight: 600;
}

.book-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.book-item {
  width: calc(50% - 10rpx);
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  overflow: hidden;
}

.cover {
  width: 100%;
  height: 280rpx;
  background: #e2e6eb;
  display: block;
}

.info {
  padding: 16rpx;
}

.title {
  font-size: 28rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.author {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.pager {
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
}

.pager-btn {
  margin: 0;
  padding: 0 28rpx;
  height: 64rpx;
  line-height: 64rpx;
}

.pager-text {
  color: var(--muted);
  font-size: 24rpx;
}
