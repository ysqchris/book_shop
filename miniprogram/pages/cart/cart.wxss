.item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.cover {
  width: 140rpx;
  height: 180rpx;
  border-radius: 10rpx;
  background: #e2e6eb;
  flex-shrink: 0;
}

.body {
  flex: 1;
  min-width: 0;
}

.title {
  font-weight: 600;
  margin-bottom: 6rpx;
}

.row {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.qty-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  margin: 0;
  padding: 0;
  line-height: 52rpx;
  font-size: 28rpx;
  background: var(--surface-raised);
  border: 1rpx solid var(--border);
  border-radius: 10rpx;
}

.qty-btn::after {
  border: none;
}

.qty {
  min-width: 36rpx;
  text-align: center;
}

.remove {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: sticky;
  bottom: 20rpx;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--ink-soft);
}

.sum {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
}

.checkout {
  margin: 0;
  min-width: 160rpx;
}

.go {
  margin-top: 28rpx;
  width: 240rpx;
}
