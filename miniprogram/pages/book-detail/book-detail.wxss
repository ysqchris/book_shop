.top {
  display: flex;
  gap: 24rpx;
}

.cover {
  width: 220rpx;
  height: 300rpx;
  border-radius: 12rpx;
  background: #e2e6eb;
  flex-shrink: 0;
}

.right {
  flex: 1;
  min-width: 0;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.line {
  font-size: 24rpx;
  margin-bottom: 6rpx;
}

.price-row {
  margin-top: 16rpx;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.price {
  font-size: 40rpx;
}

.origin {
  font-size: 22rpx;
  color: var(--muted);
  text-decoration: line-through;
}

.stock {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.qty-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  line-height: 64rpx;
  background: var(--surface-raised);
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 32rpx;
}

.qty-btn::after {
  border: none;
}

.qty {
  min-width: 48rpx;
  text-align: center;
  font-size: 30rpx;
}

.desc {
  font-size: 26rpx;
  color: var(--ink-soft);
  line-height: 1.7;
  white-space: pre-wrap;
}

.tip {
  font-size: 24rpx;
  color: var(--ink-soft);
  line-height: 1.6;
  background: var(--surface-raised);
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.action {
  flex: 1;
  margin: 0;
}
